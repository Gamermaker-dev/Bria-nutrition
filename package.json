{
	"name": "bria-nutrition",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"preview:host": "vite preview --host", 
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.18",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@google/generative-ai": "0.24.1",
		"@jamescoyle/svelte-icon": "0.1.1",
		"@layerstack/svelte-stores": "1.0.2",
		"@mdi/js": "7.4.47",
		"@prisma/client": "7.7.0",
		"@prisma/adapter-mssql": "7.7.0",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"@types/mssql": "12.3.0",
		"autoprefixer": "^10.4.27",
		"better-auth": "1.4.18",
		"clsx": "2.1.1",
		"csv-parse": "6.2.1",
		"dayjs": "1.11.20",
		"dotenv": "17.4.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"html5-qrcode": "2.3.8",
		"layerchart": "^1.0.13",
		"mysql2": "^3.16.3",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prisma": "7.7.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-preprocess": "6.0.3",
		"sveltekit-superforms": "2.30.1",
		"svelte-ux": "^1.0.10",
		"tailwindcss": "3.4.19",
		"tesseract.js": "7.0.0",
		"tsx": "4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"zod": "4.3.6"
	},
	"dependencies": {
		"@layerstack/tailwind": "^1.0.1"
	}
}
