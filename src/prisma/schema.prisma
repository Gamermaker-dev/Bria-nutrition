generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model account {
  id                       String    @id @db.VarChar(36)
  accountId               String    @db.NVarChar(450)
  providerId              String    @db.NVarChar(450)
  userId                  String    @db.VarChar(36)
  accessToken             String?   @db.NVarChar(450)
  refreshToken            String?   @db.NVarChar(450)
  idToken                 String?   @db.NVarChar(450)
  accessTokenExpiresAt  DateTime? @db.DateTime2
  refreshTokenExpiresAt DateTime? @db.DateTime2
  scope                    String?   @db.NVarChar(450)
  password                 String?   @db.NVarChar(450)
  createdAt               DateTime  @default(now()) @db.DateTime2
  updatedAt               DateTime  @db.DateTime2
  user                     user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "accountUserIdUserIdFk")

  @@index([userId], map: "accountUserIdIdx")
}

model activityLevel {
  id          BigInt    @id @unique(map: "activityLevelIdUnique") @default(autoincrement()) @db.BigInt
  name        String    @unique(map: "activityLevelNameUnique") @db.NVarChar(450)
  description String    @db.NVarChar(450)
  multiplier  Decimal?  @db.Decimal(4, 3)
  dateAdded  DateTime  @db.DateTime2
  profile     profile[]
}

model fdcNutrient {
  fdcId      BigInt @db.BigInt
  nutrientId BigInt @db.BigInt
  amount      Float  @db.Float

  @@id([fdcId, nutrientId])
  @@index([fdcId], map: "fdcIdIndx")
  @@index([nutrientId], map: "fdcNutrientNutrientIdNutrientIdFk")
}

model food {
  id            BigInt          @id @unique(map: "foodIdUnique") @default(autoincrement()) @db.BigInt
  name          String          @db.NVarChar(800)
  fdcId         Int?
  userId       String?         @db.VarChar(36)
  dateAdded    DateTime        @db.DateTime2
  foodNutrient foodNutrient[]
  mealFood     mealFood[]

  @@index([userId], map: "userIdIndx")
}

model foodNutrient {
  foodId     BigInt   @db.BigInt
  nutrientId BigInt   @db.BigInt
  amount      Float    @db.Float
  food        food     @relation(fields: [foodId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "foodNutrientFoodIdFoodIdFk")
  nutrient    nutrient @relation(fields: [nutrientId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "foodNutrientNutrientIdNutrientIdFk")

  @@id([foodId, nutrientId])
  @@index([foodId], map: "foodIdIndx")
  @@index([nutrientId], map: "foodNutrientNutrientIdNutrientIdFk")
}

model label {
  id             BigInt           @id @unique(map: "labelIdUnique") @default(autoincrement()) @db.BigInt
  name           String           @unique(map: "labelNameUnique") @db.NVarChar(450)
  dateAdded     DateTime         @db.DateTime2
  labelNutrient labelNutrient[]
  profileLabel  profileLabel[]
  recommendation recommendation[]
}

model labelNutrient {
  labelId    BigInt   @db.BigInt
  nutrientId BigInt   @db.BigInt
  label       label    @relation(fields: [labelId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "labelNutrientLabelIdLabelIdFk")
  nutrient    nutrient @relation(fields: [nutrientId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "labelNutrientNutrientIdNutrientIdFk")

  @@id([labelId, nutrientId])
  @@index([labelId], map: "labelIdIndx")
  @@index([nutrientId], map: "labelNutrientNutrientIdNutrientIdFk")
}

model meal {
  id           BigInt      @id @unique(map: "mealIdUnique") @default(autoincrement()) @db.BigInt
  mealDate    DateTime    @db.Date
  userId      String      @db.VarChar(36)
  dateAdded   DateTime    @db.DateTime2
  dateUpdated DateTime?   @db.DateTime2
  dateDeleted DateTime?   @db.DateTime2
  user         user        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mealUserIdUserIdFk")
  mealFood    mealFood[]

  @@unique([mealDate, userId], map: "userMealIndx")
  @@index([userId], map: "mealUserIdUserIdFk")
}

model mealFood {
  mealId BigInt @db.BigInt
  foodId BigInt @db.BigInt
  amount  Float  @db.Float
  food    food   @relation(fields: [foodId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mealFoodFoodIdFoodIdFk")
  meal    meal   @relation(fields: [mealId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mealFoodMealIdMealIdFk")

  @@id([mealId, foodId])
  @@index([mealId], map: "mealIdIndx")
  @@index([foodId], map: "mealFoodFoodIdFoodIdFk")
}

model nutrient {
  id              BigInt           @id @unique(map: "nutrientUdUnique") @default(autoincrement()) @db.BigInt
  name            String           @db.NVarChar(450)
  unit            String           @db.NVarChar(450)
  fdcNumber      Int
  dateAdded      DateTime         @db.DateTime2
  fdcNutrientId BigInt           @db.BigInt
  foodNutrient   foodNutrient[]
  labelNutrient  labelNutrient[]
}

model physicalType {
  id             BigInt           @id @unique(map: "physicalTypeUniqueId") @default(autoincrement()) @db.BigInt
  name           String           @db.NVarChar(450)
  dateAdded     DateTime         @db.DateTime2
  profile        profile[]
  recommendation recommendation[]
}

model profile {
  id               BigInt          @id @unique(map: "profileUniqueId") @default(autoincrement()) @db.BigInt
  userId          String          @db.VarChar(36)
  birthDate       DateTime        @db.DateTime2
  physicalTypeId BigInt          @db.BigInt
  heightInch      Int
  heightFeet      Int
  weight           Decimal         @db.Decimal(4, 1)
  activityLevelId  BigInt          @db.BigInt
  age              Int?
  nextProfileId  BigInt?         @db.BigInt
  dateAdded       DateTime        @db.DateTime2
  dateUpdated     DateTime?       @db.DateTime2
  dateDeleted     DateTime?       @db.DateTime2
  profile          profile?        @relation("profileToprofile", fields: [nextProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "nextProfileForeignKey")
  historicProfiles    profile[]       @relation("profileToprofile")
  activityLevel   activityLevel  @relation(fields: [activityLevelId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profileActivityLevelIdActivityLevelIdFk")
  physicalType    physicalType   @relation(fields: [physicalTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profilePhysicalTypeIdPhysicalTypeIdFk")
  user             user            @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profileUserIdUserIdFk")
  profileLabel    profileLabel[]

  @@index([nextProfileId], map: "nextProfileForeignKey")
  @@index([activityLevelId], map: "profileActivityLevelIdActivityLevelIdFk")
  @@index([physicalTypeId], map: "profilePhysicalTypeIdPhysicalTypeIdFk")
  @@index([userId], map: "userIdIndx")
}

model profileLabel {
  profileId BigInt  @db.BigInt
  labelId   BigInt  @db.BigInt
  label      label   @relation(fields: [labelId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profileLabelLabelIdLabelIdFk")
  profile    profile @relation(fields: [profileId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profileLabelProfileIdProfileIdFk")

  @@id([profileId, labelId])
  @@index([profileId], map: "profileIdIndx")
  @@index([labelId], map: "profileLabelLabelIdLabelIdFk")
}

model recommendation {
  id               BigInt        @id @unique(map: "recommendationUniqueId") @default(autoincrement()) @db.BigInt
  labelId         BigInt        @db.BigInt
  minAge          Int
  maxAge          Int?
  physicalTypeId BigInt        @db.BigInt
  amount           Float         @db.Float
  label            label         @relation(fields: [labelId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "recommendationLabelIdLabelIdFk")
  physicalType    physicalType @relation(fields: [physicalTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "recommendationPhysicalTypeIdPhysicalTypeIdFk")

  @@index([labelId], map: "labelIdIndx")
  @@index([physicalTypeId], map: "physicalTypeIdIndx")
}

model role {
  id        BigInt      @id @unique(map: "roleIdUnique") @default(autoincrement()) @db.BigInt
  name       String      @db.NVarChar(450)
  dateAdded DateTime    @db.DateTime2
  userRole  userRole[]
}

model session {
  id         String   @id @db.VarChar(36)
  expiresAt DateTime @db.DateTime2
  token      String   @unique(map: "sessionTokenUnique") @db.VarChar(255)
  createdAt DateTime @default(now()) @db.DateTime2
  updatedAt DateTime @db.DateTime2
  ipAddress String?  @db.NVarChar(450)
  userAgent String?  @db.NVarChar(450)
  userId    String   @db.VarChar(36)
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sessionUserIdUserIdFk")

  @@index([userId], map: "sessionUserIdIdx")
}

model user {
  id             String      @id @db.VarChar(36)
  name           String      @db.VarChar(255)
  email          String      @unique(map: "userEmailUnique") @db.VarChar(255)
  emailVerified Boolean     @default(false)
  image          String?     @db.NVarChar(450)
  createdAt     DateTime    @default(now()) @db.DateTime2
  updatedAt     DateTime    @default(now()) @db.DateTime2
  account        account[]
  meal           meal[]
  profile        profile[]
  session        session[]
  userRole      userRole[]
}

model userRole {
  userId     String   @db.VarChar(36)
  roleId    BigInt   @db.BigInt
  dateAdded DateTime @db.DateTime2
  role       role     @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "userRoleRoleIdRoleIdFk")
  user       user     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "userRoleUserIdUserIdFk")

  @@id([userId, roleId])
  @@index([roleId], map: "userRoleRoleIdIndx")
  @@index([userId], map: "userRoleUsrIdIndx")
}

model verification {
  id         String   @id @db.VarChar(36)
  identifier String   @db.VarChar(255)
  value      String   @db.NVarChar(450)
  expiresAt DateTime @db.DateTime2
  createdAt DateTime @default(now()) @db.DateTime2
  updatedAt DateTime @default(now()) @db.DateTime2

  @@index([identifier])
}
